/**
 * Generated by quail.
 *
 * Steps API — higher-level helpers for the journey specs in this suite.
 * Each helper composes the underlying Playwright primitives (click,
 * fill, expect) into a single readable verb so the specs read at the
 * shape of the journey, not the shape of the DOM.
 *
 * Specs use these helpers by importing them from `./lib/steps`:
 *
 *   import { steps } from './lib/steps'
 *   await steps.visit(page, '/')
 *   await steps.fillForm(page, { email: 'me@example.com' })
 *   await steps.submit(page)
 *
 * The bodies stay deliberately small — the rationale lives in the
 * journey-kind doc comments at the top of each spec. Extend this file
 * when a new pattern repeats across more than two specs.
 */
import { expect, type Page, type Locator } from '@playwright/test'

/** Loose options for the higher-level helpers. */
export type FormValues = Record<string, string>

/**
 * Navigate to a relative path and wait for the DOM to settle. Use this
 * over `page.goto` when you want a single point of control for the
 * default settle behaviour across the suite.
 */
async function visit(page: Page, path: string): Promise<void> {
  await page.goto(path)
  await page.waitForLoadState('domcontentloaded')
}

/**
 * Fill a set of named form inputs. Cascades from most-explicit to
 * most-permissive so humanized scenario titles ("Monthly income")
 * still resolve to inputs whose `name` attribute is `monthlyIncome`,
 * `monthly_income`, `monthly-income`, etc. Order:
 *
 *   1. getByLabel(<key>)                       — visible <label>
 *   2. getByPlaceholder(<key>)                 — placeholder text
 *   3. [name="<key>"]                          — literal name match
 *   4. [aria-label="<key>" i]                  — case-insensitive aria
 *   5. [name="<denormalised>"]                 — try camelCase / snake / kebab
 *   6. input[name*="<firstWord>" i]            — substring fallback
 *
 * Whichever matches first wins. Silently skips unmatched keys so a
 * single helper handles forms whose field set varies across pages.
 */
async function fillForm(page: Page, values: FormValues): Promise<void> {
  for (const [key, value] of Object.entries(values)) {
    const normals = denormaliseKey(key)
    const firstWord = key.trim().split(/\s+/)[0] || key
    const escapedAria = key.replace(/"/g, '\\"')
    const candidates: Locator[] = [
      page.getByLabel(key, { exact: false }),
      page.getByPlaceholder(key),
      page.locator(`[name="${key}"]`),
      page.locator(`[aria-label="${escapedAria}" i]`),
      ...normals.map(n => page.locator(`[name="${n}"]`)),
      page.locator(`input[name*="${firstWord}" i], select[name*="${firstWord}" i], textarea[name*="${firstWord}" i]`),
    ]
    for (const loc of candidates) {
      if (await loc.first().count() > 0) {
        await loc.first().fill(value)
        break
      }
    }
  }
}

/**
 * denormaliseKey turns a humanized label like "Monthly income" into
 * the identifier shapes a DOM input's `name=` is likely to use:
 * camelCase, snake_case, kebab-case, lowercase-joined. Returns the
 * variants in priority order; duplicates removed. Empty when the key
 * was already in identifier shape (no spaces).
 */
function denormaliseKey(key: string): string[] {
  const trimmed = key.trim()
  if (!/\s/.test(trimmed)) return []
  const words = trimmed.split(/\s+/).map(w => w.toLowerCase())
  if (!words.length) return []
  const camel = words[0] + words.slice(1).map(w => w[0].toUpperCase() + w.slice(1)).join('')
  const snake = words.join('_')
  const kebab = words.join('-')
  const joined = words.join('')
  const seen = new Set<string>()
  const out: string[] = []
  for (const v of [camel, snake, kebab, joined]) {
    if (!seen.has(v)) { seen.add(v); out.push(v) }
  }
  return out
}

/**
 * Click the form's submit button. v0.61 — scoped + enabled-aware.
 *
 * Pre-v0.61 picked the first submit-like button anywhere on the page.
 * On real sites the first such button is often the newsletter
 * "Subscribe" — disabled until you fill the email field, so the click
 * would hang for 30s until timeout.
 *
 * New algorithm:
 *   1. Prefer a button inside a <form> that has visible text inputs.
 *   2. Otherwise scan the whole page.
 *   3. In each scope, iterate role/text matches and pick the first
 *      that's both visible AND enabled.
 *   4. Last resort: press Enter (most forms submit on Enter).
 */
async function submit(page: Page): Promise<void> {
  const filledForm = page.locator('form').filter({
    has: page.locator('input[type="email"], input[type="text"], input[type="tel"], input[type="url"], textarea'),
  })
  const candidateRoots: Locator[] = (await filledForm.count()) > 0
    ? [filledForm.first(), page.locator('body')]
    : [page.locator('body')]

  for (const root of candidateRoots) {
    const byRole = root.getByRole('button', { name: /submit|send|sign in|sign up|subscribe|continue/i })
    const total = Math.min(await byRole.count(), 5)
    for (let i = 0; i < total; i++) {
      const btn = byRole.nth(i)
      if ((await btn.isVisible().catch(() => false)) && (await btn.isEnabled().catch(() => false))) {
        await btn.click({ timeout: 5000 })
        return
      }
    }
    const generic = root.locator('button[type="submit"], input[type="submit"]')
    const gtotal = Math.min(await generic.count(), 5)
    for (let i = 0; i < gtotal; i++) {
      const btn = generic.nth(i)
      if ((await btn.isVisible().catch(() => false)) && (await btn.isEnabled().catch(() => false))) {
        await btn.click({ timeout: 5000 })
        return
      }
    }
  }
  await page.keyboard.press('Enter').catch(() => {})
}

/** Click a nav link by visible text or href fragment. */
async function clickNav(page: Page, label: string | RegExp): Promise<void> {
  const link = page.getByRole('link', { name: label })
  if (await link.first().count() > 0) {
    await link.first().click()
    return
  }
  await page.locator(`a:has-text("${label}")`).first().click()
}

/**
 * Search the page for the search box and submit a query. Handles both
 * native input[type=search] and aria-labelled boxes.
 */
async function search(page: Page, query: string): Promise<void> {
  const box = page.locator('input[type="search"], [role="searchbox"]').first()
  await box.fill(query)
  await box.press('Enter')
}

/** Assert the URL changed to a path (or pattern). */
async function expectAt(page: Page, path: string | RegExp): Promise<void> {
  await expect(page).toHaveURL(typeof path === 'string' ? new RegExp(path + '$') : path)
}

/** Assert the page's h1 contains the given text. */
async function expectH1(page: Page, text: string | RegExp): Promise<void> {
  const name = typeof text === 'string' ? new RegExp(text, 'i') : text
  await expect(page.getByRole('heading', { level: 1, name })).toBeVisible()
}

/** Assert a selector is visible (first match). */
async function expectVisible(page: Page, selector: string): Promise<void> {
  await expect(page.locator(selector).first()).toBeVisible()
}

/** Assert a selector matches exactly `n` elements. */
async function expectCount(page: Page, selector: string, n: number): Promise<void> {
  await expect(page.locator(selector)).toHaveCount(n)
}

/**
 * Convert-journey shorthand: visit a path, fill the form, submit, and
 * assert the page didn't surface an error region. Use for newsletter /
 * lead-gen forms where the success state is "no error" rather than a
 * redirect.
 */
async function convert(page: Page, path: string, values: FormValues): Promise<void> {
  await visit(page, path)
  await fillForm(page, values)
  await submit(page)
  const errors = page.locator('form, [role="form"]').first().locator('text=/error|failed/i')
  await expect(errors).toHaveCount(0)
}

/**
 * Authenticate shorthand: visit /login (or the given path), fill
 * email + password, submit, and assert URL changed away from the login
 * page. Tweak the post-submit assertion in the spec when the app
 * redirects to a known destination.
 */
async function authenticate(page: Page, path: string, email: string, password: string): Promise<void> {
  await visit(page, path)
  await fillForm(page, { email, password })
  await submit(page)
}

export const steps = {
  visit,
  fillForm,
  submit,
  clickNav,
  search,
  expectAt,
  expectH1,
  expectVisible,
  expectCount,
  convert,
  authenticate,
}

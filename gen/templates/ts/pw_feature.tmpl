{{- /* calculator — the v0.10.13 intent specialization. Adds the
       generic 5 PLUS one RELATIONAL scenario: fill, compute, capture
       result, refill one input with a different value, resubmit,
       assert the result CHANGED. Catches the "stale result widget"
       regression that the generic happy-compute scenario can't see. */ -}}
{{- define "component_calculator" -}}
{{ template "component_generic" . }}
{{- with .Symbol.PrimaryComponent }}
{{- $first := index .Inputs 0 }}

  @journey:{{$.JourneyKind}} @priority:critical @kind:calculator-relational
  Scenario: the result reacts when an input value changes
    Given I open the landing page
{{- range $f := .Inputs }}
    When I enter "{{realisticValueFor $f}}" into the "{{humanField $f}}" field
{{- end }}
    When I submit the form
    Then a result is shown
    When I capture the current result
    When I enter "{{realisticAltValueFor $first}}" into the "{{humanField $first}}" field
    When I submit the form
    Then the result has changed
{{- end }}
{{- end }}


{{- /* v0.10.13: intent-aware dispatch for the primary-component
       block. When the LLM classifier tagged this page as a known
       intent with high confidence, route to the intent-specific
       sub-template; otherwise the generic 5-scenario suite (lifted
       from v0.10.12) fires unchanged. */ -}}
{{- with .Symbol.PrimaryComponent }}
{{- if .Inputs }}
{{- if and (eq $.Symbol.PageIntent.Intent "calculator") (ge $.Symbol.PageIntent.Confidence 0.7) }}
{{ template "component_calculator" $ }}
{{- else }}
{{ template "component_generic" $ }}
{{- end }}
{{- end }}
{{- end }}


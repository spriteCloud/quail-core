Then('no error message is shown in the form region', async ({ page }) => {
  const region = page.locator('form, [role="form"]').first()
  const errors = region.locator('text=/error|failed/i')
  await expect(errors).toHaveCount(0)
})

// v0.95.6: tolerant result assertion for the happy-compute Scenario.
// Cascades through the obvious result-shape patterns and falls back
// to "no error region present" so we never false-fail on pages whose
// result rendering we can't read. The point is to prove the widget
// computes — not to dictate how it displays.
Then('a result is shown', async ({ page }) => {
  const candidates = [
    page.locator('[role="status"]'),
    page.locator('[aria-live="polite"], [aria-live="assertive"]'),
    page.locator('[data-result], [data-test-result], [data-testid*="result" i]'),
    page.locator('output'),
    // Currency-shaped output. Real result panels carry a number with
    // a currency symbol on every calculator we've probed.
    page.locator('text=/[€$£¥]\\s?\\d/'),
  ]
  for (const loc of candidates) {
    if ((await loc.first().count()) > 0) {
      await expect(loc.first()).toBeVisible({ timeout: 5000 })
      return
    }
  }
  // Fallback: assert no error region. Pages whose result rendering
  // doesn't match the patterns above still get a real assertion —
  // the form must not be in an error state after submit.
  const region = page.locator('form, [role="form"]').first()
  const errors = region.locator('text=/error|fout|invalid|failed|niet juist/i')
  await expect(errors).toHaveCount(0)
})

// v0.10.12: sad-path siblings for the primary-component scenarios.
// Tolerant cascades — none of these assert a result *value*, but each
// is a real check that catches obvious regressions.

Then('a validation hint is shown', async ({ page }) => {
  // Cascade: HTML5 form validity → ARIA invalid → role=alert →
  // common error-text patterns across NL/EN/DE/PT/ES/FR.
  const candidates = [
    page.locator('[aria-invalid="true"]'),
    page.locator('[role="alert"]'),
    page.locator('.error, .field-error, .invalid, .has-error'),
    page.locator('text=/required|verplicht|obrigat[óo]rio|invalid|ongeldig|fout|niet juist|missing|fehlt|erforderlich|requis/i'),
  ]
  for (const loc of candidates) {
    if ((await loc.first().count()) > 0) {
      await expect(loc.first()).toBeVisible({ timeout: 5000 })
      return
    }
  }
  // Fallback: HTML5 constraint API on the first invalid input. If the
  // browser is enforcing required/min/max, that's the validation hint
  // even without a visible error region.
  const anyInvalid = await page.evaluate(() => {
    const inputs = document.querySelectorAll('input, select, textarea')
    for (const el of Array.from(inputs)) {
      const ce = el as HTMLInputElement
      if (ce.validity && !ce.validity.valid) return true
    }
    return false
  })
  expect(anyInvalid, 'expected at least one validation signal').toBe(true)
})

Then('no result is shown', async ({ page }) => {
  // Mirror of "a result is shown". For each result-shaped locator that
  // exists on the page, assert it is NOT visible. If none exist, the
  // assertion is vacuously satisfied — the page has no result widget
  // to render, so by definition no result is shown.
  const candidates = [
    page.locator('[role="status"]'),
    page.locator('[aria-live="polite"], [aria-live="assertive"]'),
    page.locator('[data-result], [data-test-result], [data-testid*="result" i]'),
    page.locator('output'),
    page.locator('text=/[€$£¥]\\s?\\d/'),
  ]
  for (const loc of candidates) {
    if ((await loc.first().count()) > 0) {
      await expect(loc.first()).not.toBeVisible({ timeout: 2000 })
      return
    }
  }
})

// v0.10.13: calculator-relational step-defs. The pair captures the
// current visible result text into a page-scoped state, then asserts
// the result text differs after refilling + resubmitting. Catches
// stale-result-widget regressions that "a result is shown" can't see.

const RESULT_LOCATORS = [
  '[role="status"]',
  '[aria-live="polite"]',
  '[aria-live="assertive"]',
  '[data-result]',
  '[data-test-result]',
  '[data-testid*="result" i]',
  'output',
]

When('I capture the current result', async ({ page }) => {
  for (const sel of RESULT_LOCATORS) {
    const loc = page.locator(sel).first()
    if ((await loc.count()) > 0) {
      const text = ((await loc.textContent()) ?? '').trim()
      ;(page as any).__capturedResult = text
      ;(page as any).__capturedResultSelector = sel
      return
    }
  }
  // Fallback: capture currency-shaped text anywhere on the page.
  const cur = page.locator('text=/[€$£¥]\\s?\\d/').first()
  if ((await cur.count()) > 0) {
    const text = ((await cur.textContent()) ?? '').trim()
    ;(page as any).__capturedResult = text
    ;(page as any).__capturedResultSelector = 'text=currency'
    return
  }
  ;(page as any).__capturedResult = null
  ;(page as any).__capturedResultSelector = null
})

Then('the result has changed', async ({ page }) => {
  const before = (page as any).__capturedResult as string | null
  const sel = (page as any).__capturedResultSelector as string | null
  if (before == null || sel == null) {
    // No result was captured the first time around — likely the
    // first submit didn't render a result at all. Treat as
    // inconclusive rather than false-fail: assert the page is at
    // least still alive. The generic component-submit Scenario will
    // catch the "result never appears" case independently.
    await expect(page.locator('body')).toBeVisible()
    return
  }
  let after: string | null = null
  if (sel === 'text=currency') {
    const cur = page.locator('text=/[€$£¥]\\s?\\d/').first()
    if ((await cur.count()) > 0) {
      after = ((await cur.textContent()) ?? '').trim()
    }
  } else {
    const loc = page.locator(sel).first()
    await expect(loc).toBeVisible({ timeout: 5000 })
    after = ((await loc.textContent()) ?? '').trim()
  }
  expect(after, 'expected the result panel to re-render after refilling an input').not.toBe(before)
})

Then('the page does not crash', async ({ page }) => {
  // The page is still alive: body visible, no generic error overlay.
  // Cheap assertion that distinguishes "this scenario was bad input
  // but the page kept running" from "this scenario broke the page".
  await expect(page.locator('body')).toBeVisible()
  await expect(
    page.locator('text=/^(500|502|503|504|Application error|Something went wrong|Internal Server Error)$/i'),
  ).toHaveCount(0)
})

Then('I remain on the same page', async ({ page }) => {
  // Implicit: the previous step (submit) didn't redirect. If a future
  // step needs a stricter assertion (URL hash unchanged, etc.) add it
  // here. The fallthrough "no success message" check below is the
  // primary signal.
  await page.waitForLoadState('domcontentloaded')
})

Then('no success message is shown', async ({ page }) => {
  await expect(page.locator('text=/success|welcome|signed in/i')).toHaveCount(0)
})


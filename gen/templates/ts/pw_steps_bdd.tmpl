Then(/^the element "([^"]+)" is visible$/, async ({ page }, selector: string) => {
  await steps.expectVisible(page, selector)
})

Then(/^the element "([^"]+)" contains text "([^"]+)"$/, async ({ page }, selector: string, text: string) => {
  await expect(page.locator(selector).first()).toContainText(new RegExp(escapeRegex(text), 'i'))
})

Then(/^the element "([^"]+)" has attribute "([^"]+)" equal to "([^"]+)"$/, async ({ page }, selector: string, attr: string, value: string) => {
  await expect(page.locator(selector).first()).toHaveAttribute(attr, value)
})

Then(/^there are (\d+) "([^"]+)" elements$/, async ({ page }, n: string, selector: string) => {
  await steps.expectCount(page, selector, Number(n))

Then(/^the URL has query parameter "([^"]+)" equal to "([^"]+)"$/, async ({ page }, key: string, value: string) => {
  expect(new URL(page.url()).searchParams.get(key)).toBe(value)
})

function escapeRegex(s: string): string {
  return s.replace(/[\\^$.*+?()[\]{}|/]/g, '\\$&')
}

// v0.10.11: tolerant URL assertion. Many sites (ING, every Adobe-AEM
// install, most marketing CMSes) normalise URLs by stripping the
// trailing slash on `/foo/` → `/foo`, or vice-versa. The generated
// `When I navigate directly to "/foo/"` step would false-fail on a
// strict `escapeRegex(href) + '$'` anchor. We tolerate the slash on
// both ends — the navigation succeeded, the path matches, that's what
// the assertion actually means.
function urlAssertionRegex(href: string): RegExp {
  const trimmed = href.replace(/\/+$/, '')
  return new RegExp(escapeRegex(trimmed) + '/?$')
}
